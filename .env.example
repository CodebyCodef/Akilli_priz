# Akıllı Priz API Konfigürasyonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
#
# cp .env.example .env

# PostgreSQL bağlantı URL'si
# Arkadaşınız (DevOps) sunucuyu hazırladığında bu URL'yi güncelleyin
DATABASE_URL=postgresql+asyncpg://user:password@HOST:5432/akilli_priz

# Frontend'in API'ye erişebilmesi için izin verilen origin'ler
# Virgülle ayırarak birden fazla origin ekleyebilirsiniz
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cihaz TCP bağlantı timeout süresi (saniye)
DEVICE_TIMEOUT=2.0

